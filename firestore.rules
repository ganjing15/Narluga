rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own graphics
    match /users/{uid}/graphics/{graphicId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Public curated examples — anyone can read, only authenticated users can write
    match /public_examples/{exampleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
